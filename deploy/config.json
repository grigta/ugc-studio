{
  "networkVolume": {
    "name": "ugc-studio-weights",
    "size": 150,
    "dataCenterId": "EU-RO-1"
  },
  "endpoints": [
    {
      "key": "image",
      "name": "ugc-image",
      "imageName": "ghcr.io/grigta/ugc-image-worker:latest",
      "containerDiskInGb": 20,
      "gpuTypeIds": ["NVIDIA RTX PRO 6000 Blackwell Server Edition"],
      "gpuCount": 1,
      "workersMin": 0,
      "workersMax": 3,
      "idleTimeout": 10,
      "scalerType": "QUEUE_DELAY",
      "scalerValue": 4,
      "executionTimeoutMs": 600000,
      "env": {}
    },
    {
      "key": "video",
      "name": "ugc-video",
      "imageName": "ghcr.io/grigta/ugc-video-worker:latest",
      "containerDiskInGb": 30,
      "gpuTypeIds": ["NVIDIA RTX PRO 6000 Blackwell Server Edition"],
      "gpuCount": 1,
      "workersMin": 0,
      "workersMax": 2,
      "idleTimeout": 15,
      "scalerType": "QUEUE_DELAY",
      "scalerValue": 4,
      "executionTimeoutMs": 1200000,
      "env": {
        "_comment": "для выдачи видео по URL задай S3/R2 креды",
        "BUCKET_ENDPOINT_URL": "",
        "BUCKET_ACCESS_KEY_ID": "",
        "BUCKET_SECRET_ACCESS_KEY": ""
      }
    },
    {
      "key": "voice",
      "name": "ugc-voice",
      "imageName": "ghcr.io/grigta/ugc-voice-worker:latest",
      "containerDiskInGb": 15,
      "gpuTypeIds": ["NVIDIA A100 80GB PCIe"],
      "gpuCount": 1,
      "workersMin": 0,
      "workersMax": 1,
      "idleTimeout": 10,
      "scalerType": "QUEUE_DELAY",
      "scalerValue": 4,
      "executionTimeoutMs": 300000,
      "env": {
        "COSYVOICE_MODEL_DIR": "/runpod-volume/models/CosyVoice2-0.5B"
      }
    },
    {
      "key": "script",
      "name": "ugc-script",
      "imageName": "runpod/worker-v1-vllm:v2.22.4",
      "containerDiskInGb": 30,
      "gpuTypeIds": ["NVIDIA A100 80GB PCIe"],
      "useVolume": false,
      "gpuCount": 1,
      "workersMin": 0,
      "workersMax": 1,
      "idleTimeout": 10,
      "scalerType": "QUEUE_DELAY",
      "scalerValue": 4,
      "executionTimeoutMs": 600000,
      "env": {
        "_comment": "vLLM-воркер. T-pro-it-2.1-FP8 (Qwen3-32B, RU), FP8 на одну A100 80GB. Без volume: воркер качает модель (~33ГБ) на cold-start — первый запрос долгий (~5-10мин), дальше быстро. Имя MODEL_NAME должно совпадать с RUNPOD_SCRIPT_MODEL в web/.env.local.",
        "MODEL_NAME": "t-tech/T-pro-it-2.1-FP8",
        "MAX_MODEL_LEN": "12000",
        "GPU_MEMORY_UTILIZATION": "0.95",
        "TRUST_REMOTE_CODE": "1",
        "DTYPE": "auto"
      }
    }
  ]
}
