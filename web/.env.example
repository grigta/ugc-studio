# Скопируй в web/.env.local и заполни (значения печатает deploy/deploy.mjs).
# RUNPOD_API_KEY НИКОГДА не попадает в браузер — используется только в /api роутах.

RUNPOD_API_KEY=

RUNPOD_IMAGE_ENDPOINT_ID=
RUNPOD_VIDEO_ENDPOINT_ID=
RUNPOD_VOICE_ENDPOINT_ID=
RUNPOD_SCRIPT_ENDPOINT_ID=

# имя модели, которую обслуживает vLLM-воркер script-эндпоинта (должно совпадать
# с MODEL_NAME в deploy/config.json)
RUNPOD_SCRIPT_MODEL=Qwen/Qwen2.5-7B-Instruct
